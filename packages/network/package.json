{
  "name": "@commonsmesh/network",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "CommonsMesh libp2p network layer: peer discovery, pubsub, relay, and sync",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@commonsmesh/protocol": "workspace:*"
  },
  "peerDependencies": {
    "libp2p": "^2.0.0",
    "@libp2p/tcp": "^10.0.0",
    "@libp2p/websockets": "^9.0.0",
    "@libp2p/noise": "^16.0.0",
    "@libp2p/yamux": "^7.0.0",
    "@libp2p/kad-dht": "^14.0.0",
    "@libp2p/gossipsub": "^14.0.0",
    "@libp2p/mdns": "^11.0.0",
    "@libp2p/circuit-relay-v2": "^3.0.0",
    "@libp2p/identify": "^3.0.0",
    "@libp2p/peer-id": "^5.0.0",
    "@multiformats/multiaddr": "^12.0.0",
    "multiformats": "^13.0.0"
  },
  "peerDependenciesMeta": {
    "libp2p": { "optional": false }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0"
  }
}
