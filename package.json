{
  "name": "commonsmesh",
  "version": "0.1.0",
  "private": true,
  "description": "CommonsMesh — decentralized community mutual aid network (monorepo)",
  "license": "AGPL-3.0-only",
  "workspaces": [
    "protocol",
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "pnpm -r --filter './protocol' build && pnpm -r --filter './packages/*' build",
    "clean": "pnpm -r clean",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint"
  },
  "devDependencies": {
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.0.0"
}
